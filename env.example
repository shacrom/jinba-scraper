# jinba-scraper environment variables
# Copy this file to .env and fill in real values.
# NOTE: sandbox-safe name — rename to .env for local use.

# -----------------------------------------------
# Supabase
# -----------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=listing-photos

# -----------------------------------------------
# Redis / BullMQ
# -----------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------
# Scraper identity (ethical scraping)
# -----------------------------------------------
USER_AGENT=JinbaBot/0.1 (+https://jinba.app/bot; contact=marmibas.dev@gmail.com)

# -----------------------------------------------
# Observability
# -----------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info

# -----------------------------------------------
# Runtime
# -----------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------
# Development helpers
# -----------------------------------------------
# Local path to jinba-db repo (for scripts/sync-db-types.ts)
# JINBA_DB_PATH=../jinba-db
